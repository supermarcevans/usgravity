---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Insights | US Gravity';
const description = 'Stratospheric thinking. Ground-level execution. IT leadership perspectives, Virtual CIO insights, and strategic technology thinking from Marc Evans at Gravity Limited.';
const permalink = `${Astro.site.href}blog`;

let allPosts = await getCollection('posts')
allPosts = allPosts.sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf());
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <div class="container">
    <div class="blog-header">
      <p class="eyebrow">Stratospheric Thinking. Ground-Level Execution.</p>
      <h1>Insights & Perspectives</h1>
      <p class="blog-intro">
        Practical thinking on IT leadership, technology strategy, team building, and the challenges facing companies in complex industries. High-altitude perspective, ground-level usefulness. Written by Marc Evans — practitioner first, consultant second.
      </p>
    </div>

    {allPosts.map((post, index) => {
      const href = `/blog/${post.data.slug}`;
      return (
        <div>
          { index !== 0 && <hr /> }
          <div class="post-item">
            <h2>
              <a href={href}>{post.data.title}</a>
            </h2>
            <p class="post-description">{post.data.description}</p>
            <div class="post-item-footer">
              <span class="post-item-date">— {post.data.publishDate}</span>
            </div>
          </div>
        </div>
      )
    })}

    <hr />
    <div class="blog-cta">
      <p>Have a topic you'd like Marc to cover? <a href="mailto:usgravity.ethically151@passfwd.com">Send a suggestion.</a></p>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-header {
    margin: 2em 0 3em;
  }

  .eyebrow {
    font-size: 0.85em;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.4em;
  }

  .blog-header h1 {
    font-size: 2.2em;
    font-weight: 700;
    margin-bottom: 0.4em;
  }

  .blog-intro {
    font-size: 1.05em;
    line-height: 1.7;
    max-width: 600px;
    color: var(--text-secondary);
  }

  h2,
  .post-item-footer {
    font-family: var(--font-family-sans);
    font-weight: 700;
  }

  .post-item {
    padding: 0.5em 0;
  }

  .post-item h2 {
    font-size: 1.5em;
    margin-bottom: 0.4em;
  }

  .post-item h2 a {
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .post-item h2 a:hover {
    opacity: 0.7;
  }

  .post-description {
    font-size: 1.05em;
    line-height: 1.65;
    margin-bottom: 0.75em;
    color: var(--text-secondary);
  }

  .post-item-date {
    color: var(--text-secondary);
    text-align: left;
    text-transform: uppercase;
    font-size: 0.85em;
    margin-right: 16px;
    letter-spacing: 0.05em;
  }

  hr {
    margin: 60px auto;
    border-color: var(--border-color, #eee);
  }

  .blog-cta {
    text-align: center;
    padding: 1.5em 0 3em;
    font-size: 1em;
    color: var(--text-secondary);
  }

  .blog-cta a {
    font-weight: 600;
  }
</style>
