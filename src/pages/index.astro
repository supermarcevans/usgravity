---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'US Gravity | Virtual CIO & IT Consulting — Denver, CO';
const description = 'Stratospheric thinking. Ground-level execution. Gravity Limited provides Virtual CIO, IT strategy, and IT leadership consulting for companies across the USA. Based in Denver, CO. Led by Marc Evans.';
const permalink = Astro.site.href;
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <div class="home-container">
    <div class="home-copy">
      <p class="eyebrow">Stratospheric Thinking. Ground-Level Execution.</p>
      <h1>Every Great Company Needs a Center of Gravity.</h1>
      <p>
        Gravity Limited partners with businesses across the USA to provide executive-level IT leadership — without the executive-level overhead. Whether you need a Virtual CIO, a sharper IT strategy, or someone to build and lead your technology team, Marc Evans brings the experience and gravity to get it done.
      </p>
      <div class="cta-group">
        <a href="mailto:usgravity.ethically151@passfwd.com" class="btn btn-primary">Let's Talk</a>
        <a href="/about" class="btn btn-secondary">About Marc</a>
      </div>
    </div>

    <div class="hero-image-container">
      <div class="gravity-visual" aria-hidden="true">
        <div class="orbit-ring ring-1"></div>
        <div class="orbit-ring ring-2"></div>
        <div class="orbit-ring ring-3"></div>
        <div class="core">
          <span>G</span>
        </div>
      </div>
    </div>
  </div>

  <section class="services-section">
    <h2>What We Do</h2>
    <p class="section-intro">Stratospheric thinking applied to the ground-level problems that actually slow your business down.</p>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">⚡</div>
        <h3>Virtual CIO (vCIO)</h3>
        <p>Get C-suite IT leadership at a fraction of the cost. Marc serves as your embedded strategic technology executive — attending leadership meetings, owning the IT roadmap, and aligning technology with your business goals.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🗺️</div>
        <h3>IT Strategy & Roadmapping</h3>
        <p>From where you are to where you need to be. We assess your current state, define your future state, and map a clear, actionable path — built around your industry, budget, and growth trajectory.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🏗️</div>
        <h3>IT Team Building & Leadership</h3>
        <p>Need to build an IT team from scratch? Strengthen the one you have? Or simply add expert bandwidth for a season? We help you hire right, lead well, and develop the internal capability your company needs to scale.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">📋</div>
        <h3>IT Project Management</h3>
        <p>Complex implementations, infrastructure overhauls, system migrations, and compliance initiatives — delivered on time and on budget with clear communication at every stage.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🛡️</div>
        <h3>Compliance & Regulatory Readiness</h3>
        <p>Navigating CMMC, SOC 2, HIPAA, or industry-specific regulatory requirements? We help you build the frameworks, documentation, and controls that keep you audit-ready and protected.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🚀</div>
        <h3>Scaling & Problem Solving</h3>
        <p>Growth is exciting — until your technology can't keep up. We identify the friction points, remove the barriers, and put the right systems and processes in place so your IT infrastructure scales as fast as your business does.</p>
      </div>
    </div>
  </section>

  <section class="industries-section">
    <h2>Industries We Serve</h2>
    <p class="section-intro">We understand the unique technology demands of complex, high-stakes industries.</p>
    <div class="industries-list">
      <span class="industry-tag">⛽ Energy</span>
      <span class="industry-tag">⛏️ Mining & Prospecting</span>
      <span class="industry-tag">🔌 Power Generation</span>
      <span class="industry-tag">🏭 Industrial Manufacturing</span>
      <span class="industry-tag">🧬 BioMedical Manufacturing</span>
      <span class="industry-tag">🚚 Logistics</span>
      <span class="industry-tag">+ Many More</span>
    </div>
  </section>

  <section class="cta-section">
    <h2>Ready to Find Your Center of Gravity?</h2>
    <p>Let's have a straightforward conversation about where your IT stands today and where it needs to go. No pressure, no jargon — just honest insight from someone who's been there.</p>
    <a href="mailto:usgravity.ethically151@passfwd.com" class="btn btn-primary btn-large">Get in Touch</a>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .home-container {
    align-items: center;
    display: flex;
    flex: 1;
    justify-content: center;
    margin: 3em 0 4em;
    min-height: 420px;
    gap: 3em;
  }

  .home-copy {
    flex: 1;
    padding: 0 1em;
    max-width: 600px;
  }

  .eyebrow {
    font-size: 0.9em;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.5em;
  }

  .home-copy h1 {
    font-weight: 700;
    margin-bottom: 0.6em;
    line-height: 1.25;
    font-size: 2.4em;
  }

  .home-copy p {
    font-size: 1.15em;
    line-height: 1.7;
    margin-bottom: 1.5em;
  }

  .cta-group {
    display: flex;
    gap: 1em;
    flex-wrap: wrap;
    margin-top: 1.5em;
  }

  .btn {
    display: inline-block;
    padding: 0.75em 1.75em;
    border-radius: 4px;
    font-weight: 700;
    font-size: 1em;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .btn:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .btn-primary {
    background: var(--text-link);
    color: #fff;
  }

  .btn-secondary {
    border: 2px solid var(--text-link);
    color: var(--text-link);
    background: transparent;
  }

  .btn-large {
    padding: 1em 2.5em;
    font-size: 1.1em;
  }

  /* ── Gravity Visual ── */
  .hero-image-container {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .gravity-visual {
    position: relative;
    width: 320px;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .orbit-ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid var(--text-link);
    opacity: 0.25;
    animation: pulse 4s ease-in-out infinite;
  }

  .ring-1 { width: 110px;  height: 110px;  animation-delay: 0s; }
  .ring-2 { width: 200px;  height: 200px;  animation-delay: 0.8s; }
  .ring-3 { width: 300px;  height: 300px;  animation-delay: 1.6s; }

  @keyframes pulse {
    0%, 100% { transform: scale(1);    opacity: 0.2; }
    50%       { transform: scale(1.03); opacity: 0.45; }
  }

  .core {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--text-link);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 40px rgba(0, 120, 255, 0.35);
    z-index: 1;
  }

  .core span {
    color: #fff;
    font-size: 2.2em;
    font-weight: 900;
    line-height: 1;
  }

  /* ── Services ── */
  .services-section {
    padding: 4em 0;
    border-top: 1px solid var(--border-color, #eee);
  }

  .services-section h2,
  .industries-section h2,
  .cta-section h2 {
    font-size: 1.9em;
    font-weight: 700;
    margin-bottom: 0.4em;
  }

  .section-intro {
    font-size: 1.1em;
    color: var(--text-secondary);
    margin-bottom: 2.5em;
    max-width: 580px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2em;
  }

  .service-card {
    padding: 1.75em;
    border: 1px solid var(--border-color, #e8e8e8);
    border-radius: 8px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .service-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.08);
    transform: translateY(-3px);
  }

  .service-icon {
    font-size: 1.8em;
    margin-bottom: 0.5em;
  }

  .service-card h3 {
    font-size: 1.1em;
    font-weight: 700;
    margin-bottom: 0.5em;
  }

  .service-card p {
    font-size: 0.95em;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  /* ── Industries ── */
  .industries-section {
    padding: 3.5em 0;
    border-top: 1px solid var(--border-color, #eee);
  }

  .industries-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75em;
    margin-top: 1.5em;
  }

  .industry-tag {
    padding: 0.5em 1.2em;
    border-radius: 999px;
    border: 1.5px solid var(--text-link);
    color: var(--text-link);
    font-size: 0.95em;
    font-weight: 600;
  }

  /* ── CTA Banner ── */
  .cta-section {
    padding: 4em 3em;
    margin: 3em 0;
    text-align: center;
    background: var(--background-body-alt, #f6f8fc);
    border-radius: 12px;
  }

  .cta-section p {
    font-size: 1.1em;
    max-width: 560px;
    margin: 0.75em auto 2em;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 800px) {
    .home-container {
      flex-direction: column;
      text-align: center;
    }

    .cta-group {
      justify-content: center;
    }

    .gravity-visual {
      width: 220px;
      height: 220px;
    }

    .ring-1 { width: 80px;  height: 80px; }
    .ring-2 { width: 145px; height: 145px; }
    .ring-3 { width: 205px; height: 205px; }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .section-intro {
      max-width: 100%;
    }
  }
</style>
